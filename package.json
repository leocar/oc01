{
  "name": "oc01",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "test": "node --test scripts/*.test.mjs && pnpm -r --if-present test",
    "test:scripts": "node --test scripts/*.test.mjs",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "format:check": "pnpm -r --if-present format:check",
    "smoke:sqlserver": "node scripts/run-rls-smoke.mjs",
    "smoke:sqlserver:local": "node scripts/run-local-rls-smoke.mjs"
  },
  "pnpm": {
    "overrides": {
      "multer": "^2.2.0"
    }
  }
}
