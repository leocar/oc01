# Copy this file to apps/api/.env for local API runtime configuration.
# Do not commit apps/api/.env or paste secrets in chat/logs.

DATABASE_URL=Server=<db-host>;Database=<db-name>;User Id=<db-user>;Password=<db-password>;Encrypt=true;TrustServerCertificate=false
AUTH_SESSION_PRIVATE_KEY=<session-private-key-pem>
AUTH_SESSION_PUBLIC_KEY=<session-public-key-pem>
SUPER_ADMIN_PASSWORD=<password>
